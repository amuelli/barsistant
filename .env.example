# Example environment configuration for Barsistant
# Copy this file to .env and fill in your own values

# AI provider to use (e.g. openai, anthropic)
AI_PROVIDER=openai

# API key for the selected AI provider (required)
OPENAI_API_KEY=your-api-key-here

# (Optional) Model to use for the selected provider (e.g. gpt-4o, gpt-4, claude-3-opus-20240229)
# If not set, defaults to 'gpt-4o' for OpenAI
AI_MODEL=gpt-4o
