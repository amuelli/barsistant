# Example environment configuration for Barsistant
# Copy this file to .env and fill in your own values

# AI provider to use (e.g. openai, anthropic)
AI_PROVIDER=openai

# API key for the selected AI provider (required)
OPENAI_API_KEY=your-api-key-here

# (Optional) Model to use for the selected provider (e.g. gpt-4o, gpt-4, claude-3-opus-20240229)
# If not set, defaults to 'gpt-4o' for OpenAI
# AI_MODEL=gpt-4o

# Example environment variables for Barsistant S3 integration
# Copy to .env and fill in your real values for local development

S3_ENDPOINT=https://your-s3-endpoint.example.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# (Optional) Remote Deno KV URL for database connection
# If set, will use remote KV instead of local
# DENO_KV_URL=https://api.deno.com/databases/your-database-id/connect
# DENO_KV_ACCESS_TOKEN=your-deno-kv-access-token
