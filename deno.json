{
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals"
  ],
  "tasks": {
    "dev": "deno run -A npm:next dev",
    "build": "deno run -A npm:next build",
    "start": "deno run -A npm:next start",
    "lint": "deno run -A npm:eslint .",
    "check": "deno task lint && deno task build"
  }
}
