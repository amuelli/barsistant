{
  "exclude": [
    ".agents/",
    ".next/",
    "node_modules/"
  ],
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals"
  ],
  "tasks": {
    "dev": "deno run -A npm:next dev",
    "build": "deno run -A npm:next build",
    "start": "deno run -A npm:next start",
    "lint": "deno run -A npm:eslint .",
    "test": "deno test",
    "typecheck": "deno check",
    "check": "deno task lint && deno task test && deno task typecheck && deno task build"
  }
}
