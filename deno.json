{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "dev": "vite",
    "start": "deno serve -A _fresh/server.js",
    "build": "vite build",
    "preview": "deno serve -A _fresh/server.js",
    "update": "deno run -Ar @fresh/update",
    "test": "deno test --allow-all",
    "init-db": "deno run --allow-read --allow-write --allow-net --allow-env scripts/init-db.ts",
    "fetch-eval-data": "deno run -A scripts/fetch-eval-data.ts",
    "eval-extraction": "deno run -A scripts/eval-extraction.ts",
    "extract-recipes": "deno run --allow-net --allow-write scripts/extract-recipes.ts",
    "migration:create": "deno run -A scripts/generate-migration.ts",
    "migration:status": "deno run -A scripts/migrations.ts status",
    "migration:run": "deno run -A scripts/migrations.ts run",
    "dump-kv": "deno run -A scripts/dump-kv.ts",
    "setup-github-mcp": "deno run --allow-read --allow-env --allow-run scripts/setup-github-mcp.ts"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": [
    "**/_fresh/*",
    "**/eval-data/**",
    "utils/db/migrations/_template.ts"
  ],
  "imports": {
    "🛠️/": "./utils/",
    "🏝️/": "./islands/",
    "🧱/": "./components/",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^2.0.32",
    "@michaelhthomas/fluxhtml": "jsr:@michaelhthomas/fluxhtml@^1.2.0",
    "@bradenmacdonald/s3-lite-client": "jsr:@bradenmacdonald/s3-lite-client@^0.9.2",
    "@fresh/core": "jsr:@fresh/core@^2.1.1",
    "@fresh/plugin-tailwind": "jsr:@fresh/plugin-tailwind@^0.0.1-alpha.9",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.4",
    "@fresh/update": "jsr:@fresh/update@^2.1.1",
    "@openai/openai": "jsr:@openai/openai@^4.102.0",
    "@preact/signals": "npm:@preact/signals@^2.3.1",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/testing": "jsr:@std/testing@^1.0.15",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.13",
    "ai": "npm:ai@^5.0.47",
    "daisyui": "npm:daisyui@^5.1.13",
    "fresh": "jsr:@fresh/core@^2.1.1",
    "node-vibrant": "npm:node-vibrant@^4.0.3",
    "preact": "npm:preact@^10.27.2",
    "tailwindcss": "npm:tailwindcss@^4.1.13",
    "vite": "npm:vite@^7.1.6",
    "zod": "npm:zod@^4.1.9"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "types": ["vite/client"],
  "unstable": ["kv"],
  "nodeModulesDir": "auto"
}
