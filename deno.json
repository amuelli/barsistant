{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "start": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A dev.ts build",
    "preview": "deno run -A main.ts",
    "update": "deno run -Ar @fresh/update",
    "test": "deno test --allow-all",
    "init-db": "deno run --allow-read --allow-write --allow-net --allow-env scripts/init-db.ts",
    "fetch-eval-data": "deno run -A scripts/fetch-eval-data.ts",
    "eval-extraction": "deno run -A scripts/eval-extraction.ts",
    "extract-recipes": "deno run --allow-net --allow-write scripts/extract-recipes.ts",
    "migration:create": "deno run -A scripts/generate-migration.ts",
    "migration:status": "deno run -A scripts/migrations.ts status",
    "migration:run": "deno run -A scripts/migrations.ts run"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": [
    "**/_fresh/*",
    "**/eval-data/**",
    "utils/db/migrations/_template.ts"
  ],
  "imports": {
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^1.3.22",
    "@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1.49",
    "@openai/openai": "jsr:@openai/openai@^4.102.0",
    "@pakornv/fresh-plugin-tailwindcss": "jsr:@pakornv/fresh-plugin-tailwindcss@2.0.0-alpha.1",
    "@preact/signals": "npm:@preact/signals@^2.2.1",
    "@std/assert": "jsr:@std/assert@^1.0.12",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.3",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0-beta.3",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@bradenmacdonald/s3-lite-client": "jsr:@bradenmacdonald/s3-lite-client@^0.9.1",
    "@fresh/update": "jsr:@fresh/update@^2.0.0-alpha.37",
    "daisyui": "npm:daisyui@^5.0.43",
    "fresh": "jsr:@fresh/core@^2.0.0-alpha.37",
    "node-vibrant": "npm:node-vibrant@^4.0.3",
    "preact": "npm:preact@^10.26.9",
    "tailwindcss": "npm:tailwindcss@^4.1.7",
    "ai": "npm:ai@^4.3.16",
    "zod": "npm:zod@^3.25.51"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": ["a", "img", "source", "body", "html", "head"]
  },
  "unstable": ["kv"],
  "nodeModulesDir": "auto"
}
